# ============================================================================
# Quantsightly — Variables d'environnement
# ============================================================================
# Copie ce fichier en `.env` et remplis les valeurs réelles.
# Le `.env` est ignoré par git (cf. .gitignore) — ne JAMAIS le commit.
# ============================================================================


# ─── Base de données auth (Prisma) ──────────────────────────────────────────
# Postgres dédié aux tables User, Session, LoginCode, Watchlist, WatchlistItem.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/quantsightlydb?schema=public"


# ─── Base de données coredata (pg Pool brut) ────────────────────────────────
# Postgres dédié aux séries économiques. Potentiellement dépréciée par l'API C++.
CODEDATA_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/coredatadb?schema=public"


# ─── Backend C++ (Bloomberg + EODHD) ────────────────────────────────────────
# URL interne de l'API C++ accédée via le reverse proxy /qs-api côté Next.
QS_BACKEND_URL=http://HOST:4000

# URL publique (côté client) utilisée par les fetch navigateur via le proxy.
NEXT_PUBLIC_QS_API_URL=/qs-api


# ─── SMTP (envoi des codes OTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=support@example.com
SMTP_PASS=REPLACE_ME
FROM_EMAIL=support@example.com


# ─── Secrets cryptographiques ───────────────────────────────────────────────
# IMPORTANT : générer avec `openssl rand -base64 64` (≥ 43 caractères chacun).
# Doivent être DIFFÉRENTS entre access token (JWT) et refresh token (opaque).
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_64
REFRESH_TOKEN_SECRET=REPLACE_WITH_ANOTHER_OPENSSL_RAND_BASE64_64


# ─── Environnement Node ─────────────────────────────────────────────────────
NODE_ENV=development
